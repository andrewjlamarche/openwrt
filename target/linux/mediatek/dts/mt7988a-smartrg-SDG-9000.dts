		status = "okay";
	};
	*/

	gpio-keys {
		compatible = "gpio-keys";
		pinctrl-names = "default";
		pinctrl-0 = <&button_pins>;

		button-reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&pio 13 GPIO_ACTIVE_LOW>;
		};
	};

	gpio-export {
		compatible = "gpio-export";

		pse0_reset {
			gpio-export,name = "pse0-reset";
			gpio-export,output = <1>;
			gpios = <&pio 24 GPIO_ACTIVE_LOW>;
		};

		pse1_reset {
			gpio-export,name = "pse1-reset";
			gpio-export,output = <1>;
			gpios = <&pio 61 GPIO_ACTIVE_LOW>;
		};

		watchdog_enable {
			gpio-export,name = "watchdog-enable";
			gpio-export,output = <1>;
			gpios = <&pio 60 GPIO_ACTIVE_HIGH>;
		};
	};

	gpio-watchdog {
		compatible = "linux,wdt-gpio";
		gpios = <&pio 62 GPIO_ACTIVE_LOW>;
		hw_algo = "toggle";
		hw_margin_ms = <25000>;
		always-running;
	};

	leds: gpio-leds {
		compatible = "gpio-leds";

		sfp_white {
			color = <LED_COLOR_ID_WHITE>;
			function = "sfp";
			gpios = <&pio 67 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "gpio";
			trigger-sources = <&pio 81 GPIO_ACTIVE_LOW>;
		};

		sfp_red {
			color = <LED_COLOR_ID_RED>;
			function = "sfp";
			gpios = <&pio 66 GPIO_ACTIVE_HIGH>;
			linux,default-trigger = "gpio";
			trigger-sources = <&pio 82 GPIO_ACTIVE_LOW>;
		};

		lan1_white {
			gpios = <&swled_gpio0 0 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_WHITE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <1>;
		};

		lan1_blue {
			gpios = <&swled_gpio0 1 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <1>;
		};

		lan1_green {
			gpios = <&swled_gpio0 2 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <1>;
		};

		lan1_red {
			gpios = <&swled_gpio0 3 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <1>;
		};

		lan2_white {
			gpios = <&swled_gpio0 4 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_WHITE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <2>;
		};

		lan2_blue {
			gpios = <&swled_gpio0 5 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <2>;
		};

		lan2_green {
			gpios = <&swled_gpio0 6 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <2>;
		};

		lan2_red {
			gpios = <&swled_gpio0 7 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <2>;
		};

		lan3_white {
			gpios = <&swled_gpio0 8 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_WHITE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <3>;
		};

		lan3_blue {
			gpios = <&swled_gpio0 9 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <3>;
		};

		lan3_green {
			gpios = <&swled_gpio0 10 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <3>;
		};

		lan3_red {
			gpios = <&swled_gpio0 11 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <3>;
		};

		lan4_white {
			gpios = <&swled_gpio0 12 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_WHITE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <4>;
		};

		lan4_blue {
			gpios = <&swled_gpio0 13 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <4>;
		};

		lan4_green {
			gpios = <&swled_gpio0 14 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <4>;
		};

		lan4_red {
			gpios = <&swled_gpio0 15 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <4>;
		};

		lan5_white {
			gpios = <&swled_gpio1 0 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_WHITE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <5>;
		};

		lan5_blue {
			gpios = <&swled_gpio1 1 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <5>;
		};

		lan5_green {
			gpios = <&swled_gpio1 2 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <5>;
		};

		lan5_red {
			gpios = <&swled_gpio1 3 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <5>;
		};

		lan6_white {
			gpios = <&swled_gpio1 4 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_WHITE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <6>;
		};

		lan6_blue {
			gpios = <&swled_gpio1 5 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <6>;
		};

		lan6_green {
			gpios = <&swled_gpio1 6 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <6>;
		};

		lan6_red {
			gpios = <&swled_gpio1 7 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <6>;
		};

		lan7_white {
			gpios = <&swled_gpio1 8 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_WHITE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <7>;
		};

		lan7_blue {
			gpios = <&swled_gpio1 9 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <7>;
		};

		lan7_green {
			gpios = <&swled_gpio1 10 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <7>;
		};

		lan7_red {
			gpios = <&swled_gpio1 11 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <7>;
		};

		lan8_white {
			gpios = <&swled_gpio1 12 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_WHITE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <8>;
		};

		lan8_blue {
			gpios = <&swled_gpio1 13 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <8>;
		};

		lan8_green {
			gpios = <&swled_gpio1 14 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <8>;
		};

		lan8_red {
			gpios = <&swled_gpio1 15 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <8>;
		};
	};

	sfp1: sfp1 {
		compatible = "sff,sfp";
		i2c-bus = <&i2c1>;
		los-gpios = <&pio 81 GPIO_ACTIVE_LOW>;
		mod-def0-gpios = <&pio 82 GPIO_ACTIVE_LOW>;
		rate-select0-gpios = <&pio 83 GPIO_ACTIVE_HIGH>;
		rate-select1-gpios = <&pio 80 GPIO_ACTIVE_HIGH>;
		tx-disable-gpios = <&pio 36 GPIO_ACTIVE_HIGH>;
		tx-fault-gpios = <&pio 37 GPIO_ACTIVE_HIGH>;
		maximum-power-milliwatt = <4000>;
	};

