		 * set fan speed
		 *
		 * 0 = off
		 * 77 = 30% duty cycle
		 * 102 = 40% duty cycle
		 * 128 - 50% duty cycle
		 * 152 - 60% duty cycle
		 * 255 = 100% duty cycle
		 */
