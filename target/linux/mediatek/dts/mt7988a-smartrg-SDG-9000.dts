&ssusb0 {
	status = "okay";
};

&ssusb1 {
	status = "okay";
};

&switch {
	status = "okay";

	ports {
		port@0 {
			status = "disabled";
		};

		port@1 {
			status = "disabled";
		};

		port@2 {
			status = "disabled";
		};

		port@3 {
			label = "mgmt";
		};
	};
};

&tphy {
	status = "okay";
};

&serial0 {
	status = "okay";
};

&watchdog {
	status = "okay";
};

&xsphy {
	status = "okay";
};
