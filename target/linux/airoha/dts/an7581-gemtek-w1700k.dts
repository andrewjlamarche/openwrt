/dts-v1/;

#include <dt-bindings/leds/common.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include "an7581.dtsi"

/ {
	model = "Gemtek W1700K";
	compatible = "airoha,gemtek-w1700k", "airoha,an7581", "airoha,en7581";

	aliases {
		serial0 = &uart1;
	};

	chosen {
		bootargs = "console=ttyS0,115200 earlycon"
		stdout-path = "serial0:115200n8";
		linux,usable-memory-range = <0x80200000 0x1fe00000>;
	};

	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		atf-reserved-memory@80000000 {
			no-map;
			reg = <0x80000000 0x00200000>; // TODO: fix this
		};
	};

	memory@80000000 { // TODO: fix this
		device_type = "memory";
		reg = <0x80000000 0x80000000>;
	};

	gpio-keys-polled {
		compatible = "gpio-keys-polled";
		poll-interval = <100>;
		btn0 {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&en7581_pinctrl 0 GPIO_ACTIVE_LOW>; // TODO: fix this
		};
	};

	leds {
		compatible = "gpio-leds";

		status_led: led0 {
			label = "status";
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_STATUS;
			gpios = <&en7581_pinctrl 20 GPIO_ACTIVE_LOW>; // TODO: fix this
			default-state = "on";
		};
	};	
};

&en7581_pinctrl {
	gpio-ranges = <&en7581_pinctrl 0 13 47>; // TODO: fix this

	mdio_pins: mdio-pins {
		mux {
			function = "mdio";
			groups = "mdio";
		};

		conf {
			pins = "gpio2";
			output-high;
		};
	};

	pcie0_rst_pins: pcie0-rst-pins {
		conf {
			pins = "pcie_reset0";
			drive-open-drain = <1>;
		};
	};

	pcie1_rst_pins: pcie1-rst-pins {
		conf {
			pins = "pcie_reset1";
			drive-open-drain = <1>;
		};
	};

	gswp1_len0_pins: gswp1-led0-pins {
		mux {
			function = "phy1_led0";
			pins = "gpio33"; // TODO: fix this
		};
	};

	gswp2_led0Ppins: gsqp2-led0-pins {
		mux {
			function = "phy2_led0";
			pins = "gpio34"; // TODO: fix this
		};
	};

	pwm_gpio18_idx10_pins: pwm-gpio18-iddx10-pins {
		funciton = "pwm";
		pins = "gpio18"; // TODO: fix this
		output-enable;
	};
};

&snfi {
	status = "okay";
};

&spi_nand {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		bootloader@0 {
			label = "bootloader";
			reg = <0x00000000 0x00200000>;
			read-only;
		};

		uenv@200000 {
			label = "uenv";
			reg = <0x00200000 0x00200000>;
		};

		dsd@400000 {
			label = "dsd";
			reg = <0x00400000 0x00200000>;
		};

		kernel@600000 {
			label = "kernel";
			reg = <0x00600000 0x04000000>;
		};

		kernel_slave@4600000 {
			label = "rootfs";
			reg = <0x04600000 0x04000000>;
		};

		system@8600000 {
			label = "overlay";
			reg = <0x08600000 0x17a00000>;
		};
	};
};

&i2c0 {
	status = "okay";
};

&pcie0 {
	pinctrl-names = "default";
	pinctrl-0 = <&pcie0_rst_pins>;
	status = "okay";
};

&pcie1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pcie1_rst_pins>;
	status = "okay";
};

&eth {
	status = "okay";

	// TODO: which are RTL8261N PHYs?
	gdm2: ethernet@2 {
		
	};
};

&gdm1 {
	status = "okay";
};

&switch {
	pinctrl-names = "default";
	pinctrl-0 = <&mdio_pins>;
	status = "okay";

	ports {
		#address-cells = <1>;
		#size-cells = <0>;
		gsw_port@1: port@1 {
			reg = <1>;
			label = "lan1";
			phy-mode = "internal";
			phy-handle = <&gsw_phy1>;
		};

		gsw_port@2: port@2 {
			reg = <2>;
			label = "lan2";
			phy-mode = "internal";
			phy-handle = <&gsw_phy2>;
		};

		port@6 {
			reg = <6>;
			label = "cpu";
			ethernet = <&gdm1>;
			phy-mode = "internal";

			fixed-link {
				speed = <10000>;
				full-duplex;
				pause;
			};
		};
	};
};

&gsw_phy1 {
	pinctrl-names = "led";
	pinctrl-0 = <&gswp1_led0_pins>;
	status = "okay";
};

&gsw_phy1_led0 {
	status = "okay";
};

&gsw_phy2 {
	pinctrl-names = "led";
	pinctrl-0 = <&gswp2_led0_pins>;
	status = "okay";
};

&gsw_phy2_led0 {
	status = "okay";
};
